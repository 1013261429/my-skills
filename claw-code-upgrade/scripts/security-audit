#!/usr/bin/env bash
# security-audit: 安全漏洞扫描
# Usage: security-audit [--deep] [--format sarif|json]

set -euo pipefail

DEEP=0
FORMAT="json"
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

while [[ $# -gt 0 ]]; do
    case $1 in
        --deep)
            DEEP=1
            shift
            ;;
        --format)
            FORMAT="$2"
            shift 2
            ;;
        *)
            shift
            ;;
    esac
done

echo "=== Security Audit Report ==="
echo "Project: $PROJECT_ROOT"
echo "Deep scan: $([[ $DEEP -eq 1 ]] && echo "yes" || echo "no")"
echo ""

# Check for secrets in code
echo "=== Secret Detection ==="
SECRET_PATTERNS=(
    "api[_-]?key\s*[:=]\s*[\"']?[a-zA-Z0-9]{32,}"
    "password\s*[:=]\s*[\"'][^\"']{8,}[\"']"
    "secret\s*[:=]\s*[\"']?[a-zA-Z0-9]{32,}"
    "token\s*[:=]\s*[\"']?[a-zA-Z0-9]{32,}"
    "AWS_ACCESS_KEY_ID\s*[:=]\s*[\"']?[A-Z0-9]{20}"
)

FOUND_SECRETS=0
for pattern in "${SECRET_PATTERNS[@]}"; do
    matches=$(grep -riE "$pattern" --include="*.rs" --include="*.py" --include="*.js" --include="*.ts" --include="*.yaml" --include="*.yml" --include="*.json" "$PROJECT_ROOT" 2>/dev/null | grep -v "example\|test\|mock" || true)
    if [[ -n "$matches" ]]; then
        echo "⚠ Potential secret found:"
        echo "$matches" | head -5
        FOUND_SECRETS=$((FOUND_SECRETS + 1))
    fi
done

if [[ $FOUND_SECRETS -eq 0 ]]; then
    echo "✓ No secrets detected"
fi

# Check dependencies for known vulnerabilities
echo ""
echo "=== Dependency Audit ==="
if [[ -f "Cargo.toml" ]] && command -v cargo >/dev/null 2>&1; then
    echo "Checking Rust dependencies..."
    cargo audit 2>/dev/null || echo "  Install cargo-audit: cargo install cargo-audit"
elif [[ -f "package.json" ]] && command -v npm >/dev/null 2>&1; then
    echo "Checking Node dependencies..."
    npm audit --json 2>/dev/null | jq -r '.vulnerabilities | to_entries[] | "  \(.key): \(.value.severity)"' 2>/dev/null || npm audit 2>/dev/null || true
elif [[ -f "requirements.txt" ]] && command -v safety >/dev/null 2>&1; then
    echo "Checking Python dependencies..."
    safety check -r requirements.txt 2>/dev/null || true
fi

# File permission checks
echo ""
echo "=== File Permission Check ==="
find "$PROJECT_ROOT" -type f -perm /002 | while read -r f; do
    echo "⚠ World-writable: $f"
done

# Generate report
REPORT_FILE="security-audit.${FORMAT}"
cat > "$REPORT_FILE" << EOF
{
  "scan_type": "security_audit",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "project": "$PROJECT_ROOT",
  "deep_scan": $DEEP,
  "secrets_found": $FOUND_SECRETS,
  "status": "$([[ $FOUND_SECRETS -gt 0 ]] && echo "warning" || echo "pass")"
}
EOF

echo ""
echo "✓ Report saved to $REPORT_FILE"
