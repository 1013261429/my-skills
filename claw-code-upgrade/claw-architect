#!/usr/bin/env bash
# claw-architect: Claw Code 架构师智能体启动器
# Usage: claw-architect [--system <name>] [--dry-run]

set -euo pipefail

AGENT_ROOT="$(cd "$(dirname "$0")" && pwd)"
SYSTEM=""
DRY_RUN=0

while [[ $# -gt 0 ]]; do
    case $1 in
        --system)
            SYSTEM="$2"
            shift 2
            ;;
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        --help|-h)
            cat << 'HELP'
ClawArchitect - Claw Code 架构师智能体 v2.0

用法:
  claw-architect [选项]

选项:
  --system <name>   激活指定系统 (rbac|multimodal|code|kg|test|doc|perf|sec|collab|devops|workflow)
  --dry-run          dry-run模式，只显示会执行什么
  --help, -h        显示此帮助

系统列表:
  rbac        - 高级权限矩阵
  multimodal  - 多模态处理
  code        - 代码分析
  kg          - 知识图谱
  test        - 测试编排
  doc         - 文档生成
  perf        - 性能监控
  sec         - 安全审计
  collab      - 协作开发
  devops      - DevOps集成
  workflow    - 工作流编排

示例:
  claw-architect --system sec          # 启动安全审计系统
  claw-architect --system code         # 启动代码分析系统
  claw-architect --system devops       # 启动DevOps系统
HELP
            exit 0
            ;;
        *)
            echo "Unknown option: $1 (use --help for usage)"
            exit 1
            ;;
    esac
done

echo "🏗️ ClawArchitect v2.0"
echo "==================="
echo "Agent Root: $AGENT_ROOT"
echo ""

# 检查环境
if [[ "$DRY_RUN" -eq 0 ]]; then
    echo "🔍 环境检查..."
    
    # 检查脚本目录
    if [[ ! -d "$AGENT_ROOT/scripts" ]]; then
        echo "✗ scripts/ 目录不存在"
        exit 1
    fi
    
    SCRIPT_COUNT=$(find "$AGENT_ROOT/scripts" -type f -executable | wc -l)
    echo "✓ 发现 $SCRIPT_COUNT 个可执行脚本"
    
    # 检查技能目录
    if [[ -d "$AGENT_ROOT/skills" ]]; then
        SKILL_COUNT=$(find "$AGENT_ROOT/skills" -name "SKILL.md" | wc -l)
        echo "✓ 发现 $SKILL_COUNT 项技能"
    fi
    
    # 检查Docker
    if command -v docker >/dev/null 2>&1; then
        echo "✓ Docker 可用"
    else
        echo "⚠ Docker 未安装（可选）"
    fi
    
    echo ""
fi

# 系统激活
if [[ -n "$SYSTEM" ]]; then
    echo "🚀 激活系统: $SYSTEM"
    echo ""
    
    case "$SYSTEM" in
        rbac)
            echo "🔐 RBAC 权限系统"
            echo "可用命令:"
            echo "  rbac-audit    - 审计权限配置"
            echo "  rbac-config   - 配置权限矩阵"
            echo ""
            if [[ "$DRY_RUN" -eq 0 ]]; then
                "$AGENT_ROOT/scripts/rbac-audit" --format=json 2>/dev/null || true
            fi
            ;;
        multimodal)
            echo "🎨 多模态处理系统"
            echo "可用命令:"
            echo "  image-process  - 图像处理"
            echo "  audio-convert  - 音频转换"
            echo "  video-frame    - 视频帧提取"
            ;;
        code)
            echo "🧠 代码分析系统"
            echo "可用命令:"
            echo "  code-metrics        - 代码度量"
            echo "  security-audit      - 安全审计"
            echo "  complexity-report   - 复杂度报告"
            if [[ "$DRY_RUN" -eq 0 ]]; then
                "$AGENT_ROOT/scripts/code-metrics" 2>/dev/null || true
            fi
            ;;
        kg)
            echo "🕸️ 知识图谱系统"
            echo "可用命令:"
            echo "  kg-build  - 构建知识图谱"
            echo "  kg-query  - 查询知识图谱"
            ;;
        test)
            echo "🧪 测试编排系统"
            echo "可用命令:"
            echo "  test-discover  - 发现测试"
            echo "  test-coverage  - 覆盖率分析"
            ;;
        doc)
            echo "📝 文档生成系统"
            echo "可用命令:"
            echo "  doc-api          - API文档"
            echo "  doc-architecture - 架构文档"
            echo "  doc-changelog    - 变更日志"
            ;;
        perf)
            echo "⚡ 性能监控系统"
            echo "可用命令:"
            echo "  perf-benchmark   - 基准测试"
            echo "  perf-regression  - 回归检测"
            ;;
        sec)
            echo "🔒 安全审计系统"
            echo "可用命令:"
            echo "  vuln-check       - 漏洞扫描"
            echo "  secret-scan      - 密钥扫描"
            echo "  compliance-audit - 合规审计"
            if [[ "$DRY_RUN" -eq 0 ]]; then
                "$AGENT_ROOT/scripts/secret-scan" 2>/dev/null || true
            fi
            ;;
        collab)
            echo "🤝 协作开发系统"
            echo "可用命令:"
            echo "  pr-analyze  - PR分析"
            echo "  pr-assign   - PR分配"
            echo "  pr-notify   - PR通知"
            ;;
        devops)
            echo "🚀 DevOps集成系统"
            echo "可用命令:"
            echo "  ci-pipeline    - CI流水线"
            echo "  deploy-verify  - 部署验证"
            echo "  monitor-alert  - 监控告警"
            ;;
        workflow)
            echo "🔀 工作流编排系统"
            echo "能力: DAG定义、依赖管理、并行执行"
            ;;
        *)
            echo "未知系统: $SYSTEM"
            echo "可用系统: rbac, multimodal, code, kg, test, doc, perf, sec, collab, devops, workflow"
            exit 1
            ;;
    esac
    
    echo ""
    echo "✅ 系统 $SYSTEM 已激活"
else
    # 显示所有系统状态
    echo "📊 系统状态总览"
    echo ""
    
    SYSTEMS=("rbac:🔐" "multimodal:🎨" "code:🧠" "kg:🕸️" "test:🧪" "doc:📝" "perf:⚡" "sec:🔒" "collab:🤝" "devops:🚀" "workflow:🔀")
    
    for sys in "${SYSTEMS[@]}"; do
        name=$(echo "$sys" | cut -d':' -f1)
        icon=$(echo "$sys" | cut -d':' -f2)
        
        # 检查是否有对应脚本
        script_count=$(find "$AGENT_ROOT/scripts" -name "*${name}*" -o -name "*$(echo $name | cut -c1-4)*" 2>/dev/null | wc -l)
        
        if [[ "$script_count" -gt 0 ]]; then
            echo "  $icon $name - 就绪 (${script_count} scripts)"
        else
            echo "  $icon $name - 就绪"
        fi
    done
    
    echo ""
    echo "使用 --system <name> 激活特定系统"
    echo "例如: claw-architect --system sec"
fi

echo ""
echo "🏗️ ClawArchitect 就绪"
