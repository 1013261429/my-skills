#!/usr/bin/env bash
# pr-analyze: PR自动化分析
# Usage: pr-analyze [--pr <number>] [--repo owner/repo]

set -euo pipefail

PR=""
REPO=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --pr)
            PR="$2"
            shift 2
            ;;
        --repo)
            REPO="$2"
            shift 2
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

if [[ -z "$PR" ]]; then
    echo "Usage: pr-analyze --pr <number> [--repo owner/repo]"
    exit 1
fi

# Auto-detect repo from git remote
if [[ -z "$REPO" ]]; then
    REPO=$(git remote get-url origin 2>/dev/null | sed 's/.*github.com[:\/]//' | sed 's/\.git$//')
fi

echo "=== PR Analysis ==="
echo "PR: #$PR"
echo "Repo: $REPO"
echo ""

if command -v gh >/dev/null 2>&1; then
    echo "=== PR Details ==="
    gh pr view "$PR" --repo "$REPO" 2>/dev/null || echo "Could not fetch PR details"
    
    echo ""
    echo "=== Files Changed ==="
    gh pr diff "$PR" --repo "$REPO" --name-only 2>/dev/null || echo "Could not fetch changed files"
    
    echo ""
    echo "=== Review Status ==="
    gh pr view "$PR" --repo "$REPO" --json reviews 2>/dev/null | jq -r '.reviews[]? | "\(.state) by \(.author.login)"' 2>/dev/null || true
else
    echo "GitHub CLI not found. Install with: https://cli.github.com/"
fi
