#!/usr/bin/env bash
# code-metrics: 代码复杂度与质量分析
# Usage: code-metrics [--language rust|python|js] [--output json|html]

set -euo pipefail

LANGUAGE=""
OUTPUT="json"
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

while [[ $# -gt 0 ]]; do
    case $1 in
        --language)
            LANGUAGE="$2"
            shift 2
            ;;
        --output)
            OUTPUT="$2"
            shift 2
            ;;
        *)
            shift
            ;;
    esac
done

# Auto-detect language
if [[ -z "$LANGUAGE" ]]; then
    if [[ -f "Cargo.toml" ]]; then
        LANGUAGE="rust"
    elif [[ -f "package.json" ]]; then
        LANGUAGE="js"
    elif [[ -f "setup.py" ]] || [[ -f "pyproject.toml" ]]; then
        LANGUAGE="python"
    else
        LANGUAGE="generic"
    fi
fi

echo "=== Code Metrics Report ==="
echo "Project: $PROJECT_ROOT"
echo "Language: $LANGUAGE"
echo ""

# Line counts
echo "=== File Statistics ==="
find "$PROJECT_ROOT" -type f \( -name "*.rs" -o -name "*.py" -o -name "*.js" -o -name "*.ts" \) -not -path "*/target/*" -not -path "*/node_modules/*" | while read -r f; do
    lines=$(wc -l < "$f")
    echo "  $f: $lines lines"
done

# Complexity analysis (basic)
echo ""
echo "=== Complexity Indicators ==="
if [[ "$LANGUAGE" == "rust" ]]; then
    # Count functions and match arms
    FUNC_COUNT=$(grep -r "^\s*fn " --include="*.rs" "$PROJECT_ROOT" | wc -l)
    MATCH_COUNT=$(grep -r "match " --include="*.rs" "$PROJECT_ROOT" | wc -l)
    echo "  Functions: $FUNC_COUNT"
    echo "  Match expressions: $MATCH_COUNT"
    
    # Check for complex functions (many lines)
    echo ""
    echo "=== Long Functions (>50 lines) ==="
    grep -r "^\s*fn " --include="*.rs" -n "$PROJECT_ROOT" | while read -r line; do
        file=$(echo "$line" | cut -d':' -f1)
        lineno=$(echo "$line" | cut -d':' -f2)
        # This is a simplified check
        : 
    done
fi

# Generate output
if [[ "$OUTPUT" == "json" ]]; then
    cat > "code-metrics.json" << EOF
{
  "project": "$PROJECT_ROOT",
  "language": "$LANGUAGE",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "summary": {
    "functions": ${FUNC_COUNT:-0},
    "match_expressions": ${MATCH_COUNT:-0}
  }
}
EOF
    echo "✓ Metrics saved to code-metrics.json"
fi
