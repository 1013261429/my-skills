#!/usr/bin/env bash
# secret-scan: 密钥与敏感信息扫描
# Usage: secret-scan [--strict] [--output secrets.json]

set -euo pipefail

STRICT=0
OUTPUT="secrets.json"
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

while [[ $# -gt 0 ]]; do
    case $1 in
        --strict)
            STRICT=1
            shift
            ;;
        --output)
            OUTPUT="$2"
            shift 2
            ;;
        *)
            shift
            ;;
    esac
done

echo "=== Secret Scan ==="
echo "Project: $PROJECT_ROOT"
echo "Strict mode: $([[ $STRICT -eq 1 ]] && echo "yes" || echo "no")"
echo ""

SECRETS_FOUND=0

# Patterns to check
PATTERNS=(
    "api[_-]?key\s*[:=]\s*[\"']?[a-zA-Z0-9]{32,}"
    "password\s*[:=]\s*[\"'][^\"']{8,}[\"']"
    "secret\s*[:=]\s*[\"']?[a-zA-Z0-9]{32,}"
    "token\s*[:=]\s*[\"']?[a-zA-Z0-9]{32,}"
    "AWS_ACCESS_KEY_ID\s*[:=]\s*[\"']?[A-Z0-9]{20}"
    "AWS_SECRET_ACCESS_KEY\s*[:=]\s*[\"']?[a-zA-Z0-9/+=]{40}"
    "private[_-]?key\s*[:=]\s*[\"']?-----BEGIN"
    "github[_-]?token\s*[:=]\s*[\"']?ghp_[a-zA-Z0-9]{36}"
    "slack[_-]?token\s*[:=]\s*[\"']?xox[baprs]-[a-zA-Z0-9]"
    "bearer\s+[a-zA-Z0-9_\-\.]+"
)

for pattern in "${PATTERNS[@]}"; do
    matches=$(grep -riEn "$pattern" --include="*.rs" --include="*.py" --include="*.js" --include="*.ts" --include="*.yaml" --include="*.yml" --include="*.json" --include="*.env*" --exclude-dir=target --exclude-dir=node_modules "$PROJECT_ROOT" 2>/dev/null | grep -vi "example\|test\|mock\|dummy\|placeholder\|your_" || true)
    
    if [[ -n "$matches" ]]; then
        echo "⚠ Pattern match: $pattern"
        echo "$matches" | head -3
        SECRETS_FOUND=$((SECRETS_FOUND + 1))
    fi
done

# Check for .env files
ENV_FILES=$(find "$PROJECT_ROOT" -name ".env*" -not -name ".env.example" 2>/dev/null || true)
if [[ -n "$ENV_FILES" ]]; then
    echo ""
    echo "⚠ Found .env files (ensure they're in .gitignore):"
    echo "$ENV_FILES" | head -5
fi

# Check .gitignore
if [[ ! -f "$PROJECT_ROOT/.gitignore" ]] || ! grep -q "\.env" "$PROJECT_ROOT/.gitignore" 2>/dev/null; then
    echo ""
    echo "⚠ Warning: .env files may not be in .gitignore"
fi

# Generate report
cat > "$OUTPUT" << EOF
{
  "scan_type": "secret_scan",
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "project": "$(basename "$PROJECT_ROOT")",
  "strict": $STRICT,
  "secrets_found": $SECRETS_FOUND,
  "status": "$([[ $SECRETS_FOUND -gt 0 ]] && echo "warning" || echo "pass")"
}
EOF

echo ""
if [[ $SECRETS_FOUND -gt 0 ]]; then
    echo "⚠ Found $SECRETS_FOUND potential secrets!"
else
    echo "✓ No secrets detected"
fi
echo "Report saved to $OUTPUT"
